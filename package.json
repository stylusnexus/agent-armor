{
  "name": "@stylusnexus/agentarmor",
  "version": "0.2.7",
  "description": "Open-source agent security framework. Detects and defends against AI Agent Traps - content injection, embedded jailbreaks, RAG poisoning, data exfiltration, and more.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "typecheck:eval": "tsc -p tsconfig.eval.json",
    "eval": "tsx scripts/eval/run-eval.ts",
    "eval:gate": "tsx scripts/eval/run-eval.ts --gate",
    "eval:multi-turn": "tsx scripts/eval/run-multi-turn-eval.ts",
    "eval:action-gate": "tsx scripts/eval/action-gate-fuzz.ts",
    "check:docs": "tsx scripts/check-doc-drift.ts",
    "docs:build": "typedoc",
    "docs:build:all": "npm run docs:build && npm --prefix packages/ml run docs:build"
  },
  "keywords": [
    "ai-security",
    "agent-safety",
    "prompt-injection",
    "llm-security",
    "agent-traps",
    "rag-poisoning",
    "content-injection",
    "jailbreak-detection",
    "data-exfiltration",
    "ai-agents"
  ],
  "author": "StylusNexus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stylusnexus/agent-armor.git"
  },
  "bugs": {
    "url": "https://github.com/stylusnexus/agent-armor/issues"
  },
  "homepage": "https://agentarmor.dev",
  "bin": {
    "agentarmor": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^9.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
